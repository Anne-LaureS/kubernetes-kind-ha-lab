{
  "title": "CPU Cluster",
  "condition": "A",
  "folderUID": "general",

  "data": [
    {
      "refId": "A",
      "queryType": "timeSeriesQuery",
      "relativeTimeRange": {
        "from": 600,
        "to": 0
      },
      "datasourceUid": "prometheus",
      "model": {
        "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\",pod!=\"\"}[5m])) / sum(machine_cpu_cores) * 100",
        "interval": "",
        "legendFormat": "CPU Cluster (%)",
        "refId": "A"
      }
    }
  ],

  "noDataState": "NoData",
  "execErrState": "Error",

  "for": "5m",
  "interval": "10s",

  "annotations": {
    "summary": "CPU cluster usage too high"
  },

  "labels": {
    "severity": "warning"
  }
}
