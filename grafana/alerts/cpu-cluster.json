{
  "title": "CPU Cluster High",
  "condition": "C",
  "folderUID": "general",

  "data": [
    {
      "refId": "A",
      "datasourceUid": "prometheus",
      "model": {
        "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\",pod!=\"\"}[5m]))",
        "refId": "A"
      }
    },
    {
      "refId": "C",
      "datasourceUid": "-100",
      "model": {
        "type": "threshold",
        "thresholds": [
          { "value": 80, "color": "red" }
        ]
      }
    }
  ],

  "for": "2m",
  "interval": "40s",

  "noDataState": "NoData",
  "execErrState": "Error",

  "labels": { "severity": "critical" },

  "annotations": {
    "summary": "CPU cluster usage too high"
  }
}
