{
  "title": "Ingress Latency P95 High",
  "condition": "C",
  "folderUID": "general",

  "data": [
    {
      "refId": "A",
      "datasourceUid": "prometheus",
      "model": {
        "expr": "histogram_quantile(0.95, sum(rate(nginx_ingress_controller_request_duration_seconds_bucket[5m])) by (le))",
        "refId": "A"
      }
    },
    {
      "refId": "C",
      "datasourceUid": "-100",
      "model": {
        "type": "threshold",
        "thresholds": [
          { "value": 0.6, "color": "red" }
        ]
      }
    }
  ],

  "for": "2m",
  "interval": "40s",

  "noDataState": "NoData",
  "execErrState": "Error",

  "labels": { "severity": "warning" },

  "annotations": {
    "summary": "Ingress P95 latency too high"
  }
}
