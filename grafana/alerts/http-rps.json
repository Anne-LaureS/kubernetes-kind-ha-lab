{
  "title": "HTTP Requests High",
  "condition": "C",
  "folderUID": "general",

  "data": [
    {
      "refId": "A",
      "datasourceUid": "prometheus",
      "model": {
        "expr": "sum(rate(nginx_ingress_controller_requests[5m]))",
        "refId": "A"
      }
    },
    {
      "refId": "C",
      "datasourceUid": "-100",
      "model": {
        "type": "threshold",
        "thresholds": [
          { "value": 1000, "color": "red" }
        ]
      }
    }
  ],

  "for": "2m",
  "interval": "10s",

  "noDataState": "NoData",
  "execErrState": "Error",

  "labels": { "severity": "warning" },

  "annotations": {
    "summary": "HTTP request rate too high"
  }
}
